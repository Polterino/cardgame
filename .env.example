# ─────────────────────────────────────────────────────────────────────────────
# Bisca Online – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of the backend server AS SEEN BY THE BROWSER.
# Since the server container exposes port 3001, set this to your
# server's public IP or domain, including the port.
#
# Examples:
#   Local network:  VITE_SOCKET_URL=http://192.168.1.100:3001
#   VPS w/ domain:  VITE_SOCKET_URL=https://bisca.yourdomain.com:3001
#   (if you put a reverse proxy in front, omit the port)
VITE_SOCKET_URL=http://YOUR_IP_OR_DOMAIN:3001

# The domain that Vite's dev server will accept connections from.
# Used as allowedHosts in vite.config.js.
# You can leave this blank for local builds.
VITE_ALLOWED_HOST=YOUR_DOMAIN
